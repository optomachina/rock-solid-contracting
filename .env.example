# Copy this file to `.env.local` for local development.
# Do not commit `.env.local`; it contains real secrets.

# Optional in local development. Without this, estimate submissions are accepted
# but email delivery is skipped.
RESEND_API_KEY=

# Recipient for estimate request emails.
ESTIMATE_TO_EMAIL=contact@azrocksolid.com

# Sender shown on estimate request emails. In production, this should use a
# verified Resend domain, for example: Rock Solid Estimates <estimates@azrocksolid.com>
ESTIMATE_FROM_EMAIL=Rock Solid Estimates <onboarding@resend.dev>
